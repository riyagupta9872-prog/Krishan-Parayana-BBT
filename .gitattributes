# Normalize all text files to LF on commit, checkout as LF
* text=auto eol=lf

# Explicitly declare text files
*.jsx text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.svg text eol=lf
*.config.js text eol=lf

# Binary files — never convert
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
